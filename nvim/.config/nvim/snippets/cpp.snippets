snippet mos_algorithm_on_tree Mo's Algorithm on tree
	#include <bits/stdc++.h>
	#pragma GCC optimize("Ofast")
	constexpr int N = 200005;
	int n, q;
	std::vector<int> g[N];
	int start[N], stop[N], cur;
	int par[N][20];
	int depth[N];
	int id[N];
	int a[N];
	void dfs(int u, int pa) {
	  cur++;
	  start[u] = cur;
	  id[cur] = u;
	  for (auto v : g[u])
	    if (v != pa) {
	      par[v][0] = u;
	      depth[v] = depth[u] + 1;
	      dfs(v, u);
	    }
	  cur++;
	  stop[u] = cur;
	  id[cur] = u;
	}
	void init() {
	  for (int i = 1; i <= 15; i++)
	    for (int j = 1; j <= n; j++) {
	      par[j][i] = par[par[j][i - 1]][i - 1];
	    }
	}
	int lca(int u, int v) {
	  if (depth[u] < depth[v]) std::swap(u, v);
	  for (int i = 15; i >= 0; i--) {
	    if (depth[par[u][i]] >= depth[v]) u = par[u][i];
	  }
	  for (int i = 15; i >= 0; i--)
	    if (par[u][i] != par[v][i]) {
	      u = par[u][i];
	      v = par[v][i];
	    }
	  if (u != v) return par[u][0];
	  return u;
	}
	int BL;
	struct que {
	  int l, r, pa, id;
	} qu[N];
	bool cmp(que a, que b) {
	  if (a.l / BL == b.l / BL) return a.r < b.r;
	  return a.l < b.l;
	}
	void add(int x) {}
	void del(int x) {}
	int dd[N];
	void change(int x) {
	  if (dd[x] == 0) {
	    add(a[x]);
	  } else {
	    del(a[x]);
	  }
	  dd[x] ^= 1;
	}
	int ans[N];
	int main() {
	  depth[1] = 1;
	  dfs(1, 0);
	  BL = sqrt(cur);
	  init();
	  for (int i = 1; i <= q; i++) {
	    int u, v;
	    std::cin >> u >> v;
	    int pa = lca(u, v);
	    if (start[u] > start[v]) std::swap(u, v);
	    if (pa == u) {
	      qu[i] = {start[u], start[v], pa, i};
	    } else
	      qu[i] = {stop[u], start[v], pa, i};
	  }
	  std::sort(qu + 1, qu + q + 1, cmp);
	  int l = qu[1].l, r = qu[1].l - 1;
	  for (int i = 1; i <= q; i++) {
	    while (l < qu[i].l) {
	      change(id[l]);
	      l++;
	    }
	    while (l > qu[i].l) {
	      l--;
	      change(id[l]);
	    }
	    while (r < qu[i].r) {
	      r++;
	      change(id[r]);
	    }
	    while (r > qu[i].r) {
	      change(id[r]);
	      r--;
	    }
	    int u = id[l], v = id[r];
	    if (qu[i].pa != u && qu[i].pa != v) change(qu[i].pa);
	    ans[qu[i].id] = 1;
	    if (qu[i].pa != u && qu[i].pa != v) change(qu[i].pa);
	  }
	  for (int i = 1; i <= q; i++) std::cout << ans[i] << '\n';
	  return 0;
	}

snippet quick_divide_and_conquer Quick Divide and Conquer
	int n, a[N], b[N];
	struct doan {
	  int l, r, pos;
	};
	deque<doan> dq;
	ll dp[N];
	ll cost(int l, int r) { return b[l] * a[r]; }
	int main() {
	  srand(time(NULL));
	  ios_base::sync_with_stdio(0);
	  cin.tie(0);
	  cout.tie(0);
	  cin >> n;
	  fo(i, 1, n) cin >> a[i];
	  fo(i, 1, n) cin >> b[i];
	  dq.push_back({2, n, 1});
	  fo(i, 2, n) {
	    dp[i] = dp[dq.front().pos] + cost(dq.front().pos, i);
	    ++dq.front().l;
	    if (dq.front().l > dq.front().r) dq.pop_front();
	    while (dq.size()) {
	      auto [l, r, pos] = dq.back();
	      if (dp[i] + cost(i, l) < dp[pos] + cost(pos, l))
	        dq.pop_back();
	      else
	        break;
	    }
	    if (dq.empty())
	      dq.pb({i + 1, n, i});
	    else {
	      auto& [l, r, pos] = dq.back();
	      int nl = l, nr = r, ans = r + 1;
	      while (nl <= nr) {
	        int mid = (nl + nr) / 2;
	        if (dp[i] + cost(i, mid) < dp[pos] + cost(pos, mid))
	          ans = mid, nr = mid - 1;
	        else
	          nl = mid + 1;
	      }
	      r = ans - 1;
	      if (ans <= n) dq.pb({ans, n, i});
	    }
	  }
	  cout << dp[n];
	}

snippet disjoint_set Disjoint Set
	struct DisjointSet {
	  std::vector<int> e;
	
	  DisjointSet(int n) { init(n); }
	
	  void init(int n) { e.assign(n, -1); }
	
	  int find(int u) { return e[u] < 0 ? u : e[u] = find(e[u]); }
	
	  bool merge(int u, int v) {
	    u = find(u), v = find(v);
	    if (u == v) return false;
	    if (e[u] > e[v]) std::swap(u, v);
	    e[u] += e[v];
	    e[v] = u;
	    return true;
	  }
	
	  bool is_connected(int u, int v) { return find(u) == find(v); }
	
	  int size(int u) { return -e[find(u)]; }
	};

snippet fenwick_tree_2d Fenwick Tree 2D
	struct FenwickTree2D {
	  std::vector<std::vector<int>> bit;
	  int n, m;
	  FenwickTree2D(int _n, int _m)
	      : bit(_n + 1, std::vector<int>(_m + 1)), n(_n), m(_m) {}
	  void update(int r, int c, int x) {
	    for (int idr = r; idr <= n; idr += idr & (-idr))
	      for (int idc = c; idc <= m; idc += idc & (-idc))
	        bit[idr][idc] += x;
	  }
	  int get(int r, int c) {
	    int ans = 0;
	    for (int idr = r; idr; idr -= idr & (-idr)) {
	      for (int idc = c; idc; idc -= idc & (-idc)) {
	        ans += bit[idr][idc];
	      }
	    }
	    return ans;
	  }
	};
	FenwickTree2D fw1(0, 0), fw2(0, 0), fw3(0, 0), fw4(0, 0);
	void upd(int x, int y, int v) {
	  fw1.update(x, y, v);
	  fw2.update(x, y, x * v);
	  fw3.update(x, y, y * v);
	  fw4.update(x, y, x * y * v);
	}
	void change(int x, int y, int u, int v, int val) {
	  upd(u + 1, v + 1, val);
	  upd(x, y, val);
	  upd(u + 1, y, -val);
	  upd(x, v + 1, -val);
	}
	int qry(int x, int y) {
	  int ans = 0;
	  ans += (x + 1) * (y + 1) * fw1.get(x, y);
	  ans -= (y + 1) * fw2.get(x, y);
	  ans -= (x + 1) * fw3.get(x, y);
	  ans += fw4.get(x, y);
	  return ans;
	}
	int query(int x, int y, int u, int v) {
	  return qry(u, v) - qry(u, y - 1) - qry(x - 1, v) +
	         qry(x - 1, y - 1);
	}

snippet iterative_segment_tree Iterative Segment Tree
	template <typename T>
	struct IterativeSegmentTree {
	  int n;
	  std::vector<T> tree;
	  IterativeSegmentTree(int _n) : n(_n), tree(2 * n) {}
	  template <typename Vec>
	  IterativeSegmentTree(const Vec& v) : n(v.size()), tree(2 * n) {
	    for (int i = n; i < 2 * n; i++) tree[i] = T::from(v[i - n]);
	    for (int i = n - 1; i > 0; i--)
	      tree[i] = tree[i << 1] + tree[i << 1 | 1];
	  }
	  void modify(int p, const T& v) {
	    for (tree[p += n] = v; p >>= 1;)
	      tree[p] = tree[p << 1] + tree[p << 1 | 1];
	  }
	  T query(int l, int r) {
	    T resl = T(), resr = T();
	    for (l += n, r += n; l < r; l >>= 1, r >>= 1) {
	      if (l & 1) resl = resl + tree[l++];
	      if (r & 1) resr = tree[--r] + resr;
	    }
	    return resl + resr;
	  }
	  T get(int i) const { return tree[i + n]; }
	};
	struct Info {
	  int64_t v = 0;
	  static Info from(int64_t x) { return {x}; }
	  friend Info operator+(const Info& l, const Info& r) {
	    return {l.v + r.v};
	  }
	};

snippet lazy_segment_tree Lazy Segment Tree
	template <typename T, typename L, typename F = std::plus<T>>
	struct SegmentTree {
	  int n;
	  std::vector<T> tree;
	  std::vector<L> lazy;
	  SegmentTree() {}
	  SegmentTree(int _n) { init(_n); }
	  void init(int _n) {
	    n = _n;
	    tree.assign(2 * n - 1, T());
	    lazy.assign(2 * n - 1, L());
	  }
	  template <typename Vec>
	  void build(int x, int l, int r, const Vec& v) {
	    if (l == r - 1) {
	      tree[x] = T::from_value(v[l]);
	      return;
	    }
	    int m = (l + r) / 2, y = x + 1, z = x + (m - l) * 2;
	    build(y, l, m, v);
	    build(z, m, r, v);
	    tree[x] = F()(tree[y], tree[z]);
	  }
	  template <typename Vec>
	  void build(const Vec& v) {
	    init(v.size());
	    build(0, 0, n, v);
	  }
	  template <typename Vec>
	  SegmentTree(const Vec& v) {
	    build(v);
	  }
	  inline void apply(int x, const L& t) {
	    tree[x].apply(t);
	    lazy[x].apply(t);
	  }
	  inline void push(int x, int y, int z) {
	    apply(y, lazy[x]);
	    apply(z, lazy[x]);
	    lazy[x] = L();
	  }
	  inline void pull(int x, int y, int z) {
	    tree[x] = F()(tree[y], tree[z]);
	  }
	  void modify(int x, int l, int r, int p, const T& v) {
	    if (l == r - 1) {
	      tree[x] = v;
	      return;
	    }
	    int m = (l + r) / 2, y = x + 1, z = x + (m - l) * 2;
	    push(x, y, z);
	    if (p < m)
	      modify(y, l, m, p, v);
	    else
	      modify(z, m, r, p, v);
	    pull(x, y, z);
	  }
	  void range_apply(int x, int l, int r, int ql, int qr,
	                   const L& t) {
	    if (ql <= l && r <= qr) {
	      apply(x, t);
	      return;
	    }
	    int m = (l + r) / 2, y = x + 1, z = x + (m - l) * 2;
	    push(x, y, z);
	    if (m > ql) range_apply(y, l, m, ql, qr, t);
	    if (m < qr) range_apply(z, m, r, ql, qr, t);
	    pull(x, y, z);
	  }
	  T range_query(int x, int l, int r, int ql, int qr) {
	    if (ql <= l && r <= qr) {
	      return tree[x];
	    }
	    int m = (l + r) / 2, y = x + 1, z = x + (m - l) * 2;
	    push(x, y, z);
	    if (m <= ql) return range_query(z, m, r, ql, qr);
	    if (m >= qr) return range_query(y, l, m, ql, qr);
	    return F()(range_query(y, l, m, ql, qr),
	               range_query(z, m, r, ql, qr));
	  }
	  inline void modify(int p, const T& v) {
	    assert(0 <= p && p < n);
	    modify(0, 0, n, p, v);
	  }
	  // NOTE: [l, r)
	  inline void range_apply(int l, int r, const L& t) {
	    assert(0 <= l && l < r && r <= n);
	    range_apply(0, 0, n, l, r, t);
	  }
	  // NOTE: [l, r)
	  inline T range_query(int l, int r) {
	    assert(0 <= l && l < r && r <= n);
	    return range_query(0, 0, n, l, r);
	  }
	};
	struct Tag {
	  int64_t v = 0;
	  inline void apply(const Tag& t) { v += t.v; }
	};
	struct Info {
	  int64_t v = -1e18;
	  inline void apply(const Tag& t) { v += t.v; }
	  friend Info operator+(const Info& l, const Info& r) {
	    return {std::max(l.v, r.v)};
	  }
	};

snippet line_deque Line Deque
	template <typename T = long long, bool GET_MIN = false>
	struct LineDeque {
	  struct Line {
	    mutable T a, b, p;
	    bool operator<(const Line& other) const { return a < other.a; }
	    bool operator<(T x) const { return p < x; }
	    T eval(T x) const { return a * x + b; }
	  };
	  using Set = std::deque<Line>;
	  using Iterator = typename Set::iterator;
	  Set s;
	  static const T inf = std::numeric_limits<T>::max();
	  // doubles: inf = 1/.0, div(a, b) = a / b
	  T div(T a, T b) {  // floored division
	    return a / b - ((a ^ b) < 0 && a % b);
	  }
	  bool intersect(Line& x, Line& y) {
	    if (x.a == y.a)
	      x.p = x.b > y.b ? inf : -inf;
	    else
	      x.p = div(y.b - x.b, x.a - y.a);
	    return x.p >= y.p;
	  }
	  void _add_line1(T a, T b) {  // increasing slope
	    Line to_add = {a, b, inf};
	    if (s.size()) {
	      intersect(s.back(), to_add);
	    }
	    while (s.size() >= 2 &&
	           intersect(s.at(s.size() - 2), s.at(s.size() - 1))) {
	      s.pop_back();
	      intersect(s.back(), to_add);
	    }
	    s.push_back(to_add);
	  }
	  void _add_line2(T a, T b) {  // decreasing slope
	    Line to_add = {a, b, 0};
	    while (s.size() && intersect(to_add, s.front())) {
	      s.pop_front();
	    }
	    s.push_front(to_add);
	  }
	  void add_line_increasing_slope(T a, T b) {
	    if constexpr (GET_MIN) {
	      _add_line2(-a, -b);
	    } else {
	      _add_line1(a, b);
	    }
	  }
	  void add_line_decreasing_slope(T a, T b) {
	    if constexpr (GET_MIN) {
	      _add_line1(-a, -b);
	    } else {
	      _add_line2(a, b);
	    }
	  }
	  T query(T x) {  // arbitrary
	    assert(!s.empty());
	    auto l = *std::lower_bound(s.begin(), s.end(), x);
	    if constexpr (GET_MIN)
	      return -l.eval(x);
	    else
	      return l.eval(x);
	  }
	  T query_increasing(T x) {
	    while (s.size() >= 2 && s[0].eval(x) <= s[1].eval(x))
	      s.pop_front();
	    if constexpr (GET_MIN)
	      return -s[0].eval(x);
	    else
	      return s[0].eval(x);
	  }
	  T query_decreasing(T x) {
	    while (s.size() >= 2 &&
	           s.at(s.size() - 1).eval(x) <= s.at(s.size() - 2).eval(x))
	      s.pop_back();
	    if constexpr (GET_MIN)
	      return -s.back().eval(x);
	    else
	      return s.back().eval(x);
	  }
	};

snippet line_multiset Line Multiset
	template <typename T = long long, bool GET_MIN = false>
	struct LineMultiset {
	  struct Line {
	    mutable T a, b, p;
	    bool operator<(const Line& other) const { return a < other.a; }
	    bool operator<(T x) const { return p < x; }
	  };
	  using Set = std::multiset<Line, std::less<>>;
	  using Iterator = typename Set::iterator;
	  Set s;
	  static const T inf = std::numeric_limits<T>::max();
	  // doubles: inf = 1/.0, div(a, b) = a / b
	  T div(T a, T b) {  // floored division
	    return a / b - ((a ^ b) < 0 && a % b);
	  }
	  bool intersect(Iterator x, Iterator y) {
	    if (y == s.end()) return x->p = inf, 0;
	    if (x->a == y->a)
	      x->p = x->b > y->b ? inf : -inf;
	    else
	      x->p = div(y->b - x->b, x->a - y->a);
	    return x->p >= y->p;
	  }
	  void add_line(T a, T b) {
	    if constexpr (GET_MIN) a = -a, b = -b;
	    auto z = s.insert({a, b, 0}), y = z++, x = y;
	    while (intersect(y, z)) z = s.erase(z);
	    if (x != s.begin() && intersect(--x, y))
	      intersect(x, y = s.erase(y));
	    while ((y = x) != s.begin() && (--x)->p >= y->p)
	      intersect(x, s.erase(y));
	  }
	  T query(T x) {
	    assert(!s.empty());
	    auto l = *s.lower_bound(x);
	    if constexpr (GET_MIN)
	      return -l.a * x - l.b;
	    else
	      return l.a * x + l.b;
	  }
	};

snippet modular_integer Modular Integer
	template <int MOD>
	struct Modular {
	  int v;
	
	  static constexpr Modular raw(int x) {
	    Modular res;
	    res.v = x;
	    return res;
	  }
	
	  constexpr Modular() : v(0) {}
	
	  template <typename T>
	  static constexpr int normalize(const T& x) {
	    int64_t val = static_cast<int64_t>(x);
	    if (val >= -mod() && val < mod()) {
	      int res = static_cast<int>(val);
	      return res + (res < 0) * mod();
	    }
	    val %= mod();
	    return static_cast<int>(val + (val < 0) * mod());
	  }
	
	  static constexpr int mod() { return MOD; }
	
	  template <typename U>
	  constexpr Modular(const U& x) : v(normalize(x)) {}
	
	  constexpr const int& operator()() const { return v; }
	
	  template <typename U>
	  constexpr explicit operator U() const {
	    return static_cast<U>(v);
	  }
	
	  using M = Modular;
	
	  template <typename U>
	  friend constexpr std::enable_if_t<std::is_integral_v<U>, M> power(M b, U e) {
	    assert(e >= 0);
	    M ans = 1;
	    while (e) {
	      if (e & 1) ans *= b;
	      b *= b;
	      e >>= 1;
	    }
	    return ans;
	  }
	
	  constexpr M inv() const {
	    int a = v, b = mod(), u = 1, w = 0;
	    while (b != 0) {
	      int t = a / b;
	      a -= t * b;
	      std::swap(a, b);
	      u -= t * w;
	      std::swap(u, w);
	    }
	    assert(a == 1);  // Inverse doesn't exist if GCD(v, mod) != 1
	    return M::raw(u + (u < 0 ? mod() : 0));  // Ensure positive before raw()
	  }
	
	  constexpr M& operator+=(const M& y) {
	    return v += y.v, v -= (v >= mod()) * mod(), *this;
	  }
	  constexpr M& operator-=(const M& y) {
	    return v -= y.v, v += (v < 0) * mod(), *this;
	  }
	  constexpr M& operator*=(const M& y) {
	    return v = static_cast<int>(static_cast<int64_t>(v) * y.v % mod()), *this;
	  }
	  constexpr M& operator/=(const M& y) { return *this *= y.inv(); }
	
	  constexpr M& operator++() { return v++, v -= (v >= mod()) * mod(), *this; }
	  constexpr M& operator--() { return v--, v += (v < 0) * mod(), *this; }
	
	  constexpr M operator++(int) {
	    M res(*this);
	    return ++(*this), res;
	  }
	  constexpr M operator--(int) {
	    M res(*this);
	    return --(*this), res;
	  }
	
	  constexpr M operator+() const { return *this; }
	  constexpr M operator-() const { return M::raw(v ? mod() - v : 0); }
	
	  friend constexpr bool operator==(const M& x, const M& y) {
	    return x.v == y.v;
	  }
	  friend constexpr bool operator<(const M& x, const M& y) { return x.v < y.v; }
	  friend constexpr bool operator>(const M& x, const M& y) { return x.v > y.v; }
	  friend constexpr bool operator<=(const M& x, const M& y) {
	    return x.v <= y.v;
	  }
	  friend constexpr bool operator>=(const M& x, const M& y) {
	    return x.v >= y.v;
	  }
	  friend constexpr bool operator!=(const M& x, const M& y) {
	    return x.v != y.v;
	  }
	
	  template <typename Istream>
	  friend Istream& operator>>(Istream& is, M& y) {
	    int64_t x;
	    is >> x;
	    y.v = y.normalize(x);
	    return is;
	  }
	
	  template <typename Ostream>
	  friend Ostream& operator<<(Ostream& os, const M& y) {
	    return os << y.v;
	  }
	
	  friend constexpr M operator+(const M& x, const M& y) { return M(x) += y; }
	  friend constexpr M operator-(const M& x, const M& y) { return M(x) -= y; }
	  friend constexpr M operator*(const M& x, const M& y) { return M(x) *= y; }
	  friend constexpr M operator/(const M& x, const M& y) { return M(x) /= y; }
	};
	
	constexpr int MOD = (int)${0:1e9 + 7};
	using Mint = Modular<MOD>;
	

snippet offline_fenwick_tree_2d Offline Fenwick Tree 2D
	template <typename T>
	struct OfflineFenwickTree2D {
	  int n;
	  std::vector<int> sum, vals;
	  std::vector<T> bit;  // Flattened BIT values
	  Offline2DFenwickTree(int n_row,
	                       std::vector<std::pair<int, int>>& upd_coords)
	      : n(n_row), sum(n + 1, 0) {
	    std::sort(upd_coords.begin(), upd_coords.end(),
	              [](const auto& a, const auto& b) {
	                return a.second < b.second;
	              });
	    std::vector<int> ptr(n + 1, -1);
	    for (const auto& [r, c] : upd_coords)
	      for (int x = r; x < n; x |= x + 1)
	        if (ptr[x] != c) sum[x + 1]++, ptr[x] = c;
	    for (int i = 0; i < n; i++) sum[i + 1] += sum[i];
	    vals.resize(sum[n]), bit.resize(sum[n]);
	    ptr = sum;
	    for (const auto& [r, c] : upd_coords)
	      for (int x = r; x < n; x |= x + 1)
	        if (ptr[x] == sum[x] || vals[ptr[x] - 1] != c)
	          vals[ptr[x]++] = c;
	  }
	  inline int get_index(int x, int y) {
	    auto it_begin = vals.begin() + sum[x];
	    auto it_end = vals.begin() + sum[x + 1];
	    return std::lower_bound(it_begin, it_end, y) - it_begin;
	  }
	  void update(int r, int c, const T& v) {  // (r, c) 0-indexed
	    for (int x = r; x < n; x |= x + 1)
	      for (int y = get_index(x, c); y < sum[x + 1] - sum[x];
	           y |= y + 1)
	        bit[sum[x] + y] += v;
	  }
	  T query(int r, int c) {  // query sum on [0, r) x [0, c)
	    T ans = 0;
	    for (int x = r; x > 0; x &= x - 1)
	      for (int y = get_index(x - 1, c); y > 0; y &= y - 1)
	        ans += bit[sum[x - 1] + y - 1];
	    return ans;
	  }
	};

